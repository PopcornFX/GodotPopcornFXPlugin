[configuration]

entry_symbol = "popcornfx_init"
compatibility_minimum = 4.5

[libraries]

windows.editor.x86_64 = "res://addons/popcornfx/libs/libpopcornfx.windows.editor.x86_64.dll"
windows.debug.x86_64 = "res://addons/popcornfx/libs/libpopcornfx.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/popcornfx/libs/libpopcornfx.windows.template_release.x86_64.dll"

linux.editor.x86_64 = "res://addons/popcornfx/libs/libpopcornfx.linux.editor.x86_64.so"
linux.debug.x86_64 = "res://addons/popcornfx/libs/libpopcornfx.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/popcornfx/libs/libpopcornfx.linux.template_release.x86_64.so"

macos.editor = "res://addons/popcornfx/libs/libpopcornfx.macos.editor.framework"
macos.debug = "res://addons/popcornfx/libs/libpopcornfx.macos.template_debug.framework"
macos.release = "res://addons/popcornfx/libs/libpopcornfx.macos.template_release.framework"

android.debug.arm64 = "res://addons/popcornfx/libs/libpopcornfx.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/popcornfx/libs/libpopcornfx.android.template_release.arm64.so"

ios.debug = "res://addons/popcornfx/libs/libpopcornfx.ios.template_debug.xcframework"
ios.release = "res://addons/popcornfx/libs/libpopcornfx.ios.template_release.xcframework"

[dependencies]
ios.debug = {
    "res://addons/popcornfx/libs/libgodot-cpp.ios.template_debug.xcframework": "",
    "res://addons/popcornfx/libs/libpopcornfx-runtime.ios.template_debug.xcframework": "",
}
ios.release = {
    "res://addons/popcornfx/libs/libgodot-cpp.ios.template_release.xcframework": "",
    "res://addons/popcornfx/libs/libpopcornfx-runtime.ios.template_debug.xcframework": "",
}

[icons]
PopcornFXEmitter3D = "res://addons/popcornfx/icons/PopcornFXEmitter3D.svg"
